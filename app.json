{
  "expo": {
    "name": "keuangan",
    "slug": "keuangan",
    "scheme": "keuangan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.izar26.keuangan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      "expo-sqlite",
      "expo-image",
      "expo-status-bar",
      "expo-system-ui",
      "expo-sharing",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Izinkan Keuangan memakai Face ID untuk membuka data finansial lokal."
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "BudgetPulseWidget",
              "displayName": "Budget Pulse",
              "description": "Lihat sisa budget dan status harian tanpa membuka aplikasi.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "headers": {
          "Cross-Origin-Embedder-Policy": "credentialless",
          "Cross-Origin-Opener-Policy": "same-origin"
        }
      },
      "eas": {
        "projectId": "284e0c1a-6a60-46fb-9531-1d8086e78897"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/284e0c1a-6a60-46fb-9531-1d8086e78897"
    }
  }
}
